{
  "name": "rentars-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend for Rentars — decentralized P2P rental platform on Stellar",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:api": "bash tests/api/simple.test.sh && bash tests/api/endpoints.test.sh && bash tests/api/profile.test.sh",
    "test:docker": "bash tests/docker/integration.test.sh"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.1.0",
    "sharp": "^0.33.5",
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "p-limit": "^7.3.0",
    "rate-limiter-flexible": "^5.0.5",
    "redis": "^6.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
