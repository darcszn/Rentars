{
  "name": "rentars-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend for Rentars — decentralized P2P rental platform on Stellar",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:api": "bash tests/api/simple.test.sh && bash tests/api/endpoints.test.sh && bash tests/api/profile.test.sh",
    "test:docker": "bash tests/docker/integration.test.sh"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.3.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "p-limit": "^6.1.0",
    "redis": "^4.6.12",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "bun-types": "latest",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "vitest": "^1.0.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  }
}
