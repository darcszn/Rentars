# Server
PORT=3000
NODE_ENV=production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
JWT_SECRET=your_production_jwt_secret_min_32_chars

# CORS
CORS_ORIGIN=https://your-domain.com

# Redis
REDIS_URL=redis://your-redis-host:6379

# Stellar / Soroban
STELLAR_NETWORK=mainnet
STELLAR_RPC_URL=https://soroban-rpc.stellar.org

# Contract IDs (mainnet deployment)
PROPERTY_LISTING_CONTRACT_ID=your_property_listing_contract_id_mainnet
BOOKING_CONTRACT_ID=your_booking_contract_id_mainnet

# TrustlessWork escrow API (production)
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_production_trustless_work_api_key

# Geocoding (optional)
GEOCODING_API_KEY=your_geocoding_api_key